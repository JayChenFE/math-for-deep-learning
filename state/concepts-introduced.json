{
  "1.1": [
    {
      "concept": "数据类型 (Data Type)",
      "definition": "决定计算机如何存储和解释内存中二进制数据的标签，Python 基础数值类型为 int / float / bool",
      "used_in": [
        "全书基础"
      ]
    },
    {
      "concept": "IEEE 754 浮点数",
      "definition": "二进制近似存储小数，导致 0.1 + 0.2 ≠ 0.3，浮点比较需用容差法",
      "used_in": [
        "第20章(混合精度)",
        "第22章(softmax溢出)"
      ]
    },
    {
      "concept": "浮点比较",
      "definition": "用 math.isclose() 或 |a-b| < EPS 判断相等，禁用 ==",
      "used_in": [
        "第10章(数值微分)",
        "第22章(softmax)"
      ]
    }
  ],
  "1.2": [
    {
      "concept": "NumPy 数组 (ndarray)",
      "definition": "同类型、连续内存的多维数组，支持向量化运算，是 AI 计算的基石",
      "used_in": [
        "全书代码基础"
      ]
    },
    {
      "concept": "向量化 (Vectorization)",
      "definition": "用数组级运算替代 Python 显式循环，利用 C 层面 SIMD 并行加速",
      "used_in": [
        "第4章(向量运算)",
        "第5章(点积)",
        "第6章(矩阵乘法)"
      ]
    }
  ],
  "1.3": [
    {
      "concept": "函数 (Function)",
      "definition": "输入到输出的映射规则，Python 中用 def 定义；整个神经网络本质是 f(x; θ)",
      "used_in": [
        "第10章(导数)",
        "第14章(计算图)",
        "第30章(训练循环)"
      ]
    },
    {
      "concept": "matplotlib 绘图模板",
      "definition": "plot_function() 可复用模板：np.linspace 采样 → plt.plot 画线 → 标注坐标轴和图例",
      "used_in": [
        "第2章(割线动画)",
        "第12章(梯度下降轨迹)",
        "第22章(softmax曲线)"
      ]
    }
  ],
  "2.1": [
    {
      "concept": "割线 (Secant Line)",
      "definition": "穿过曲线上两点的直线，其斜率 = (f(b)−f(a))/(b−a)，代表区间上的平均变化率",
      "used_in": [
        "第10章(导数定义)",
        "第12章(梯度下降步长直觉)"
      ]
    },
    {
      "concept": "平均变化率 (Average Rate of Change)",
      "definition": "函数在区间 [a, b] 上的总变化量除以区间长度，几何上等于割线斜率",
      "used_in": [
        "第10章(导数定义对照)"
      ]
    }
  ],
  "2.2": [
    {
      "concept": "瞬时变化率 (Instantaneous Rate of Change)",
      "definition": "当区间长度 h→0 时平均变化率的极限值，即导数 f'(x)",
      "used_in": [
        "第10章(导数符号计算)",
        "第12章(梯度)"
      ]
    },
    {
      "concept": "切线 (Tangent Line)",
      "definition": "割线在 h→0 时的极限位置，其斜率 = 导数 f'(x)",
      "used_in": [
        "第10章",
        "第12章(梯度下降可视化)"
      ]
    },
    {
      "concept": "数值微分 (Numerical Differentiation)",
      "definition": "用有限差分 (f(x+h)−f(x))/h 近似导数，h 选取需平衡近似误差与舍入误差",
      "used_in": [
        "第10章(与符号微分对比)",
        "第13章(与自动微分对比)"
      ]
    },
    {
      "concept": "数值微分的 h 选取",
      "definition": "h 太大则近似粗糙，h 太小(<1e-12)则浮点舍入误差主导；最优范围 1e-5 ~ 1e-8",
      "used_in": [
        "第10章(梯度检验)",
        "第28章(手写反向传播验证)"
      ]
    }
  ],
  "2.3": [
    {
      "concept": "matplotlib.animation",
      "definition": "用 FuncAnimation 创建逐帧动画，可视化数学概念的动态收敛过程",
      "used_in": [
        "第12章(梯度下降轨迹动画)",
        "第24章(优化路径动画)"
      ]
    }
  ],
  "2.4": [
    {
      "concept": "导数 (Derivative)",
      "definition": "f'(x) = lim(h→0) [f(x+h)−f(x)]/h，函数在某点的瞬时变化率，几何上等于切线斜率",
      "used_in": [
        "第10章(导数公式)",
        "第11章(偏导数)",
        "第12章(梯度)",
        "第13章(链式法则)",
        "第14章(自动微分)"
      ]
    },
    {
      "concept": "可导 (Differentiable)",
      "definition": "函数在某点导数极限存在，则该点可导；深度学习要求激活函数和损失函数几乎处处可导",
      "used_in": [
        "第14章(计算图要求)",
        "第28章(反向传播前提)"
      ]
    }
  ],
  "3.1": [
    {
      "concept": "Scalar",
      "definition": "0D, shape=(), e.g. loss value",
      "used_in": [
        "全書"
      ]
    }
  ],
  "3.2": [
    {
      "concept": "Vector",
      "definition": "1D array, shape=(n,), e.g. user features",
      "used_in": [
        "Ch4",
        "Ch5",
        "Ch29"
      ]
    }
  ],
  "3.3": [
    {
      "concept": "Matrix",
      "definition": "2D table, shape=(m,n), e.g. batch input",
      "used_in": [
        "Ch6",
        "Ch7",
        "Ch29"
      ]
    }
  ],
  "3.4": [
    {
      "concept": "Tensor",
      "definition": "3D+ array, e.g. Transformer (batch,seq_len,d_model)",
      "used_in": [
        "Ch29"
      ]
    }
  ],
  "3.5": [
    {
      "concept": "Axis",
      "definition": "Dimension index; sum along axis removes that dim",
      "used_in": [
        "Ch6",
        "Ch22",
        "Ch29"
      ]
    }
  ],
  "4.1-4.3": [
    {
      "concept": "Vector add/mul/sub",
      "definition": "Parallelogram rule, scalar scaling, difference",
      "used_in": [
        "Ch5",
        "Ch6"
      ]
    }
  ],
  "4.4": [
    {
      "concept": "Word Embedding Arithmetic",
      "definition": "king-man+woman~queen",
      "used_in": [
        "Ch29"
      ]
    }
  ],
  "5.1-5.2": [
    {
      "concept": "Dot Product & Cosine Similarity",
      "definition": "a*b=sum(a_i*b_i)=|a||b|cos(theta)",
      "used_in": [
        "Ch6",
        "Ch29"
      ]
    }
  ],
  "5.3-5.4": [
    {
      "concept": "Batch Q@K^T",
      "definition": "All query-key similarity scores at once",
      "used_in": [
        "Ch29"
      ]
    }
  ],
  "6.1-6.2": [
    {
      "concept": "Matrix Multiplication",
      "definition": "C[i,j]=row_i(A)*col_j(B), core of neural nets",
      "used_in": [
        "Ch7",
        "Ch26-30"
      ]
    }
  ],
  "6.3": [
    {
      "concept": "Linear Transform Geometry",
      "definition": "Matrix warps space grid",
      "used_in": [
        "Ch8",
        "Ch28"
      ]
    }
  ],
  "6.4": [
    {
      "concept": "Linear Layer",
      "definition": "output = X@W.T + b, nn.Linear math",
      "used_in": [
        "Ch26-30"
      ]
    }
  ],
  "6.5": [
    {
      "concept": "Broadcasting",
      "definition": "Auto-expand dims from last axis, dim=1 or match",
      "used_in": [
        "Ch29",
        "Ch30"
      ]
    }
  ],
  "7.1-7.3": [
    {
      "concept": "Inverse/Singular/Pseudoinverse",
      "definition": "A^-1 undoes A; singular=det=0; pinv=least-squares fallback",
      "used_in": [
        "Ch26"
      ]
    }
  ],
  "7.4": [
    {
      "concept": "Normal Equation",
      "definition": "w=(X^T X)^-1 X^T y, one-step optimal weights",
      "used_in": [
        "Ch26"
      ]
    }
  ],
  "8.1-8.2": [
    {
      "concept": "Eigenvalue & Eigenvector",
      "definition": "A*v=lambda*v; v direction unchanged, only scaled",
      "used_in": [
        "Ch9 SVD",
        "Ch17 PCA"
      ]
    }
  ],
  "8.3": [
    {
      "concept": "Eigenvalue Decay",
      "definition": "Large lambda=rich info direction; small lambda=discardable",
      "used_in": [
        "Ch9",
        "Ch17"
      ]
    }
  ]
}