        "Ch29"
      ]
    }
  ],
  "3.4": [
    {
      "concept": "Tensor",
      "definition": "3D+ array, e.g. Transformer (batch,seq_len,d_model)",
      "used_in": [
        "Ch29"
      ]
    }
  ],
  "3.5": [
    {
      "concept": "Axis",
      "definition": "Dimension index; sum along axis removes that dim",
      "used_in": [
        "Ch6",
        "Ch22",
        "Ch29"
      ]
    }
  ],
  "4.1-4.3": [
